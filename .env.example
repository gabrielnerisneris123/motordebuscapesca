# Database
POSTGRES_DB=motordebusca
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
DATABASE_URL=postgresql+asyncpg://admin:admin123@localhost:5432/motordebusca
DATABASE_URL_SYNC=postgresql://admin:admin123@localhost:5432/motordebusca

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
SECRET_KEY=mude-esta-chave-em-producao
DEBUG=true

# Crawler Settings
CRAWL_DELAY_MIN=1.0
CRAWL_DELAY_MAX=4.0
MAX_CONCURRENT_REQUESTS=10
MAX_PAGES_PER_DOMAIN=500
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Worker
DISCOVERY_INTERVAL_MINUTES=60
SCRAPER_WORKERS=4
BATCH_SIZE=50

# Search
SEARCH_QUERIES_PER_CYCLE=20
MAX_SEARCH_RESULTS=50
